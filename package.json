    "htmldiff-js": "^1.0.5",
    "lowlight": "^3.3.0",
    "lucide-react": "^0.344.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-hot-toast": "^2.5.2",
    "react-icons": "^5.6.0",
    "react-image-crop": "^11.0.10",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
