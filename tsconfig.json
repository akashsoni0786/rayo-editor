{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "resolveJsonModule": true,
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./src",
    "paths": {
      "@/*": [
        "./*"
      ]
    },
    "jsx": "react-jsx"
  },
  "include": [
    "src/index.ts",
    "src/components/project/blog-writer/**/*",
    "src/components/tiptap-templates/**/*",
    "src/components/tiptap-ui/**/*",
    "src/components/tiptap-ui-primitive/**/*",
    "src/components/tiptap-extension/**/*",
    "src/components/tiptap-icons/**/*",
    "src/components/tiptap-node/**/*",
    "src/components/shared/**/*",
    "src/components/ui/**/*",
    "src/extensions/**/*",
    "src/hooks/**/*",
    "src/lib/**/*",
    "src/utils/**/*",
    "src/types/**/*",
    "src/constants/**/*",
    "src/styles/**/*",
    "src/vite-env.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "__tests__"
  ]
}
